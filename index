<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>정수와 유리수 허들 레이스 & 타임어택</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&display=swap" rel="stylesheet">
    
    <script>MathJax = { options: { enableMenu: false }, startup: { typeset: false } };</script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    
    <style>
        :root { --bg-1: #F0FAFF; --bg-2: #81D4FA; --bg-3: #03A9F4; --bg-4: #FFCC80; --bg-5: #FF8A65; --bg-6: #A9BCF5; --bg-7: #B39DDB; --bg-ta: #E8F5E9; }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; font-family: 'Noto Sans KR', sans-serif; overflow: hidden; background-color: var(--bg-1); transition: background-color 1s; }
        
        .screen { position: absolute; width: 500px; height: 850px; left: 50%; top: 50%; transform: translate(-50%, -50%); display: flex; flex-direction: column; align-items: center;  justify-content: center; }
        #start-screen, #ta-select-screen { background-color: #f0f4f8; z-index: 100; }
        #game-screen { display: none; z-index: 10; }
        #result-screen { display: none; background: rgba(0,0,0,0.85); color: white; z-index: 200; }
        
        .title-box { text-align: center; margin-bottom: 30px; }
        .title-box h1 { font-size: 3rem; color: #1a237e; margin: 0; line-height: 1.2; }
        .title-box p { font-size: 1.2rem; color: #555; font-weight: bold; }
        .student-id-input { padding: 15px; font-size: 1.2rem; border-radius: 10px; border: 2px solid #1a237e; width: 250px; text-align: center; outline: none; margin-bottom: 20px;}
        
        .btn-common { padding: 15px 30px; font-size: 1.2rem; color: white; border: none; border-radius: 50px; cursor: pointer; box-shadow: 0 5px 15px rgba(0,0,0,0.2); margin: 10px; width: 280px; font-weight: bold; transition: transform 0.1s; }
        .btn-common:active { transform: translateY(3px); }
        .start-btn { background: #283593; }
        .ta-btn { background: #00897B; }
        .submit-btn { background: #ff9800; }
        .restart-btn { background: #4caf50; width: 100%; margin: 10px 0; }
        .back-btn { background: #757575; width: 200px; }
        
        .ta-cat-btn { background: #0288D1; padding: 15px 20px; font-size: 1.1rem; }
        
        .track { position: absolute; bottom: 0; width: 200%; left: -50%; height: 35%; background: #d4a373; border-top: 10px solid #fff; }
        #ui-panel { position: absolute; top: 20px; width: 90%; display: flex; justify-content: space-between; font-size: 1.2rem; font-weight: bold; color: #333; z-index: 20; left: 0; right: 0; margin: 0 auto; }
        
        /* 타임어택 전용 UI 요소 */
        .ta-timer { color: #d32f2f; font-size: 1.4rem; background: #fff; padding: 2px 10px; border-radius: 10px; border: 2px solid #d32f2f; }
        .ta-stats { color: #1a237e; }
        .ta-stats span.o { color: #2e7d32; }
        .ta-stats span.x { color: #c62828; }
        
        /* 🏁 미니 진행도 스타일 (허들 모드 전용) */
        #progress-bar-container {
            position: absolute; top: 55px; width: 85%; height: 30px; display: flex; justify-content: space-between; align-items: flex-end; z-index: 20; left: 0; right: 0; margin: 0 auto; border-bottom: 3px solid #8D6E63; 
        }
        .mini-hurdle { width: 4px; height: 12px; background: #333; position: relative; }
        .mini-hurdle::before { content: ''; position: absolute; top: -3px; left: -4px; width: 12px; height: 4px; background: white; border: 1px solid #333; border-radius: 2px; }
        #runner-icon { position: absolute; font-size: 1.5rem; bottom: 0px; left: calc(0% - 15px); transition: left 0.5s ease-in-out; z-index: 21; transform: scaleX(-1); }

        .combo-badge { position: absolute; top: 80px; font-size: 2.5rem; color: #ff4081; opacity: 0; transform: scale(0.5); transition: 0.3s; pointer-events: none; text-shadow: 2px 2px white; z-index: 30; width: 100%; left: 0; text-align: center; }
        
        #hurdle-container { position: relative; width: 550px; height: 250px; margin-bottom: 200px; display: flex; flex-direction: column; align-items: center; }
        .hurdle-bar { width: 100%; height: 160px; background: #fff; border: 8px solid #333; border-radius: 15px; display: flex; align-items: center; justify-content: center; position: relative; z-index: 2; box-shadow: 0 10px 20px rgba(0,0,0,0.15); }
        .hurdle-leg { width: 15px; height: 100px; background: #333; position: absolute; bottom: -90px; }
        .leg-left { left: 40px; } .leg-right { right: 40px; }
        
        #math-problem { font-size: 2.1rem; transition: opacity 0.3s ease, transform 0.3s ease; }
        #hurdle-container.hurdle-pass #math-problem { opacity: 0; transform: scale(0.5); }
        @keyframes shake { 0%, 100% { transform: translateX(0); } 20%, 60% { transform: translateX(-10px); } 40%, 80% { transform: translateX(10px); } }
        .shake { animation: shake 0.4s; }
        
        .input-display { width: 250px; height: 70px; background: #fff; border-radius: 10px; margin-top: 20px; font-size: 2rem; display: flex; align-items: center; justify-content: center; border: 3px solid #1a237e; box-shadow: 0 4px 6px rgba(0,0,0,0.1); z-index: 10; }
        #keypad { position: absolute; bottom: 20px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; width: 95%; max-width: 500px; z-index: 20; left: 0; right: 0; margin: 0 auto; }
        .key { background: #fff; border: 2px solid #333; border-radius: 10px; height: 60px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; cursor: pointer; box-shadow: 0 4px 0 #999; transition: transform 0.1s; }
        .key:active { transform: translateY(4px); box-shadow: 0 0 0 #999; }
        .key.enter { background: #4caf50; color: white; border-color: #2e7d32; }
        .key.del { background: #f44336; color: white; border-color: #c62828; }
        
        .result-content { text-align: center; background: white; color: #333; padding: 30px; border-radius: 20px; width: 90%; max-width: 450px; max-height: 90vh; overflow-y: auto; }
        #display-id {font-size: 1.3rem; margin-bottom: 10px; display: block;}
        .wrong-list { list-style: none; padding: 15px; margin-bottom: 20px; background: #fff3f3; border: 1px solid #ffcdd2; text-align: left; border-radius: 10px; }
        .ans-user { color: #d32f2f; margin-right: 15px; }
        .ans-correct { color: #1976d2; font-weight: bold; }
        
        @media (max-height: 700px) {
            #hurdle-container { transform: scale(0.8); margin-bottom: 150px; }
            #keypad { bottom: 10px; }
            .key { height: 50px; }
            .btn-common { padding: 12px 20px; font-size: 1.1rem; }
        }
    </style>
</head>
<body>

    <div id="start-screen" class="screen">
        <div class="title-box">
            <h1>🏃‍♂️ 수학 허들<br>& 타임어택</h1>
            <p>정수와 유리수 사칙계산</p>
        </div>
        <input type="tel" id="student-id" class="student-id-input" placeholder="학번 4자리 (예: 1205)" maxlength="4" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 4);">
        <button class="btn-common start-btn" onclick="checkIdAndProceed('hurdle')">🏃 종합 허들 레이스</button>
        <button class="btn-common ta-btn" onclick="checkIdAndProceed('ta-menu')">⏱️ 타임어택 연습장</button>
    </div>

    <div id="ta-select-screen" class="screen" style="display: none;">
        <div class="title-box">
            <h1 style="color: #00897B;">⏱️ 타임어택</h1>
            <p>3분 동안 약점 집중 공략!</p>
        </div>
        <button class="btn-common ta-cat-btn" onclick="startTimeAttack(1)">1. 정수의 덧셈, 뺄셈</button>
        <button class="btn-common ta-cat-btn" onclick="startTimeAttack(2)">2. 정수의 곱셈, 나눗셈</button>
        <button class="btn-common ta-cat-btn" onclick="startTimeAttack(3)">3. 유리수의 사칙계산</button>
        <button class="btn-common back-btn" onclick="goBackToMain()" style="margin-top: 30px;">돌아가기</button>
    </div>
    
    <div id="how-to-screen" class="screen" style="display: none; background-color: #fff; z-index: 150; text-align: center; padding: 20px;">
        <div class="result-content" style="box-shadow: none;">
            <h2 style="color: #283593;">🎮 게임 방법</h2>
            <ul style="text-align: left; line-height: 1.8; font-size: 1.1rem; color: #333;">
                <li>➗ <b>분수 입력:</b> <span style="color: #d32f2f; font-weight: bold;">/</span> 기호를 사용하여 입력 (예: 1/2)</li>
                <li>➖ <b>음수 입력:</b> <span style="color: #d32f2f; font-weight: bold;">-</span> 기호를 먼저 누르세요.</li>
            </ul>
            <p style="margin-top: 20px; color: #666; font-weight: bold;">3초 후 게임이 시작됩니다...</p>
        </div>
    </div>
    
    <div id="game-screen" class="screen">
        <div class="track"></div>
        
        <div id="ui-panel">
            <div id="ui-hurdle-left">LEVEL: <span id="lv-text">1</span>/7</div>
            <div id="ui-hurdle-center">STREAK: <span id="streak-text">0</span>/5</div>
            
            <div id="ui-ta-left" style="display:none;" class="ta-timer">⏳ <span id="ta-time">03:00</span></div>
            <div id="ui-ta-center" style="display:none;" class="ta-stats">
                <span class="o">O: <span id="ta-correct-text">0</span></span> | 
                <span class="x">X: <span id="ta-wrong-text">0</span></span>
            </div>
            
            <div>SCORE: <span id="score-text">0</span></div>
        </div>
        
        <div id="progress-bar-container">
            <div class="mini-hurdle"></div>
            <div class="mini-hurdle"></div>
            <div class="mini-hurdle"></div>
            <div class="mini-hurdle"></div>
            <div class="mini-hurdle"></div>
            <div class="mini-hurdle"></div>
            <div class="mini-hurdle"></div>
            <div id="runner-icon">🏃‍♂️</div>
        </div>
        
        <div id="combo-pop" class="combo-badge">0 COMBO!</div>
        <div id="hurdle-container">
            <div class="hurdle-bar" id="hurdle-bar"><div id="math-problem"></div></div>
            <div class="hurdle-leg leg-left"></div><div class="hurdle-leg leg-right"></div>
            <div class="input-display" id="user-input-view"></div>
        </div>
        
        <div id="keypad">
            <div class="key" onclick="press('7')">7</div><div class="key" onclick="press('8')">8</div><div class="key" onclick="press('9')">9</div><div class="key del" onclick="press('del')">DEL</div>
            <div class="key" onclick="press('4')">4</div><div class="key" onclick="press('5')">5</div><div class="key" onclick="press('6')">6</div><div class="key" onclick="press('-')">-</div>
            <div class="key" onclick="press('1')">1</div><div class="key" onclick="press('2')">2</div><div class="key" onclick="press('3')">3</div><div class="key" onclick="press('/')">/</div>
            <div class="key" onclick="press('0')">0</div><div class="key" onclick="press('.')">.</div><div class="key enter" onclick="checkAnswer()">확인</div>
        </div>
    </div>

    <div id="result-screen" class="screen">
        <div class="result-content">
            <h2 id="res-title">게임 결과</h2>
            <p id="display-id" style="font-weight:bold; color:#1a237e;"></p>
            
            <h1 id="res-score" style="margin: 10px 0;">0점</h1>
            <div id="res-ta-stats" style="display:none; font-size: 1.5rem; font-weight: bold; margin-bottom: 10px;">
                <span style="color:#2e7d32;">맞힘: <span id="res-ta-o">0</span></span> / 
                <span style="color:#c62828;">틀림: <span id="res-ta-x">0</span></span>
            </div>
            
            <p id="time-text" style="color:#d32f2f; font-weight:bold; margin-top: 0;"></p>
            <hr>
            
            <div id="history-area">
                <p style="font-weight:bold; color:#2e7d32; text-align:left;">🏆 최근 허들 기록</p>
                <ul id="history-list" class="wrong-list" style="background: #e8f5e9; border-color: #c8e6c9;"></ul>   
            </div>
            
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <p id="wrong-title" style="font-weight:bold; color:#d32f2f; text-align:left; margin: 0;">📝 오답 노트</p>
                <p id="weak-type-display" style="font-size: 0.9rem; color: #7b1fa2; font-weight: bold; margin: 0; background: #f3e5f5; padding: 3px 8px; border-radius: 5px;"></p>
            </div>
            <ul id="wrong-list" class="wrong-list" style="margin-top: 10px; max-height: 150px; overflow-y: auto;"></ul>
            
            <div id="submit-area">
                <button id="submit-btn" class="btn-common submit-btn" onclick="submitToGoogle()">결과 제출하기</button>
            </div>
            <button class="btn-common restart-btn" onclick="resetGame()">메인 화면으로</button>
        </div>
    </div>

    <script>
        // ★ 중요: 여기에 선생님의 웹 앱 URL을 넣으세요!
        var webAppUrl = "https://script.google.com/macros/s/AKfycbzve0rwt4YiqmMmkcqj961MdtR8jCwlUYrnuX9umWgG0s3cJxTW36YJByP5Ai0RsBpBcw/exec";

        // 시스템 상태 변수
        let gameMode = 'hurdle'; // 'hurdle' or 'timeattack'
        let taCategory = 1;      // 1, 2, 3
        let taTimeLeft = 180;    // 3분
        let taTimer = null;
        let taCorrectCount = 0;
        let taWrongCount = 0;

        let lv = 1, score = 0, combo = 0, streak = 0, strikes = 0;
        let startTime, endTime, currentInput = "", currentAns = "", currentProblemTex = "", studentId = "";
        let wrongLog = [];
        const bgColors = ['#F0FAFF','#81D4FA','#03A9F4','#FFCC80','#FF8A65','#A9BCF5', '#B39DDB']; 

        function fmt(n) { return n < 0 ? `(${n})` : `${n}`; }
        function getGCD(a,b) { a=Math.abs(a); b=Math.abs(b); while(b>0) { let t=b; b=a%b; a=t; } return a; }
        function fmtFrac(n,d) { if(n%d===0) return fmt(n/d); let g=getGCD(n,d); n/=g; d/=g; let isNeg=(n/d)<0; let tex=`\\frac{${Math.abs(n)}}{${Math.abs(d)}}`; if(isNeg) tex=`-${tex}`; return isNeg?`\\left( ${tex} \\right)`:tex; }
        function toLatex(str) { if(!str) return "\\square"; if(str.includes('/')) { let p=str.split('/'); let s=p[0].startsWith('-')?"-":""; return `${s}\\frac{${p[0].replace('-','')}}{${p[1]||"\\square"}}`; } return str; }
        function parseFraction(str) { if(!str) return NaN; let p=str.split('/'); return p.length===1?parseFloat(p[0]):parseFloat(p[0])/parseFloat(p[1]); }

        function updateRunnerPosition(level) {
            let runner = document.getElementById('runner-icon');
            if(runner && gameMode === 'hurdle') {
                let percent = (level - 1) * (100 / 6);
                runner.style.left = `calc(${percent}% - 15px)`;
            }
        }

        // 학번 검증 후 다음 화면으로 이동
        function checkIdAndProceed(target) {
            studentId = document.getElementById('student-id').value.trim(); 
            let idNum = parseInt(studentId, 10);
            let isValid = false;
            
            if (/^\d{4}$/.test(studentId)) {
                if ((idNum >= 1101 && idNum <= 1130) || (idNum >= 1201 && idNum <= 1230) ||
                    (idNum >= 1301 && idNum <= 1330) || (idNum >= 1401 && idNum <= 1430)) {
                    isValid = true;
                }
            }

            if (!isValid) { 
                alert("유효한 학번을 입력해 주세요!");
                return; 
            } 
            
            localStorage.setItem('h_last_id', studentId);
            
            if (target === 'hurdle') {
                gameMode = 'hurdle';
                startGameFlow();
            } else if (target === 'ta-menu') {
                document.getElementById('start-screen').style.display = 'none';
                document.getElementById('ta-select-screen').style.display = 'flex';
            }
        }

        function goBackToMain() {
            document.getElementById('ta-select-screen').style.display = 'none';
            document.getElementById('start-screen').style.display = 'flex';
        }

        function startTimeAttack(category) {
            gameMode = 'timeattack';
            taCategory = category;
            document.getElementById('ta-select-screen').style.display = 'none';
            startGameFlow();
        }

        function startGameFlow() {
            const isFirstTime = !sessionStorage.getItem('h_played_once');
            document.getElementById('start-screen').style.display = 'none';

            if (isFirstTime) {
                document.getElementById('how-to-screen').style.display = 'flex';
                sessionStorage.setItem('h_played_once', 'true'); 
                setTimeout(() => {
                    document.getElementById('how-to-screen').style.display = 'none';
                    enterGame();
                }, 3000);
            } else {
                enterGame();
            }
        }

        function enterGame() {
            // UI 세팅
            if (gameMode === 'hurdle') {
                document.getElementById('ui-hurdle-left').style.display = 'block';
                document.getElementById('ui-hurdle-center').style.display = 'block';
                document.getElementById('progress-bar-container').style.display = 'flex';
                document.getElementById('ui-ta-left').style.display = 'none';
                document.getElementById('ui-ta-center').style.display = 'none';
                document.body.style.backgroundColor = bgColors[0];
                updateRunnerPosition(lv); 
            } else { // Time Attack
                document.getElementById('ui-hurdle-left').style.display = 'none';
                document.getElementById('ui-hurdle-center').style.display = 'none';
                document.getElementById('progress-bar-container').style.display = 'none';
                document.getElementById('ui-ta-left').style.display = 'block';
                document.getElementById('ui-ta-center').style.display = 'block';
                document.body.style.backgroundColor = 'var(--bg-ta)';
                
                taTimeLeft = 180;
                taCorrectCount = 0;
                taWrongCount = 0;
                document.getElementById('ta-time').innerText = "03:00";
                
                // 3분 타이머 시작
                taTimer = setInterval(() => {
                    taTimeLeft--;
                    let m = Math.floor(taTimeLeft / 60).toString().padStart(2, '0');
                    let s = (taTimeLeft % 60).toString().padStart(2, '0');
                    document.getElementById('ta-time').innerText = `${m}:${s}`;
                    if (taTimeLeft <= 0) {
                        clearInterval(taTimer);
                        endTime = Date.now();
                        gameOver(true); // 시간 종료
                    }
                }, 1000);
            }

            startTime = Date.now(); 
            document.getElementById('game-screen').style.display = 'flex'; 
            updateUI();
            nextQuestion(); 
        }
        
        function press(v) { 
            if (v === 'del') {
                currentInput = currentInput.slice(0, -1);
            } else if (currentInput.length < 12) {
                if (v === '/' && currentInput.includes('/')) return; 
                if (v === '.' && currentInput.includes('.')) return; 
                if (v === '-' && currentInput !== "") return;        
                currentInput += v; 
            }
            renderInput(); 
        }

        function renderInput() { let v=document.getElementById('user-input-view'); v.innerHTML=currentInput===""?"":`\\( ${toLatex(currentInput)} \\)`; MathJax.typesetPromise([v]); }
        function nextQuestion() { currentInput=""; renderInput(); strikes=0; document.getElementById('hurdle-bar').style.backgroundColor='white'; document.getElementById('hurdle-bar').classList.remove('shake'); document.getElementById('hurdle-container').classList.remove('hurdle-pass'); generateMath(); }
        function rand(min,max) { return Math.floor(Math.random()*(max-min+1))+min; }

        function generateMath() {
            let q = "";
            
            if (gameMode === 'timeattack') {
                if (taCategory === 1) { // 정수 덧셈 뺄셈
                    let n1 = rand(-20, 20), n2 = rand(-20, 20), op = Math.random() > 0.5 ? '+' : '-';
                    q = `${fmt(n1)} ${op} ${fmt(n2)}`;
                    currentAns = (op === '+' ? n1 + n2 : n1 - n2).toString();
                } 
                else if (taCategory === 2) { // 정수 곱셈 나눗셈
                    let n1 = rand(-15, 15), n2 = rand(-15, 15); if (n2 === 0) n2 = 2;
                    let op = Math.random() > 0.5 ? '\\times' : '\\div';
                    if (op === '\\times') { q = `${fmt(n1)} \\times ${fmt(n2)}`; currentAns = (n1 * n2).toString(); }
                    else { q = `${fmt(n1)} \\div ${fmt(n2)}`; currentAns = n1 + "/" + n2; }
                } 
                else if (taCategory === 3) { // 유리수 사칙계산
                    let subType = rand(1, 3);
                    if (subType === 1) { // 소수
                        let sign1 = Math.random() > 0.5 ? 1 : -1, sign2 = Math.random() > 0.5 ? 1 : -1;
                        let d1 = (sign1 * (rand(0, 9) + rand(1, 9)/10)).toFixed(1);
                        let d2 = (sign2 * (rand(0, 9) + rand(1, 9)/10)).toFixed(1);
                        let op = Math.random() > 0.5 ? '+' : '-';
                        q = `${fmt(d1)} ${op} ${fmt(d2)}`;
                        currentAns = (op === '+' ? parseFloat(d1) + parseFloat(d2) : parseFloat(d1) - parseFloat(d2)).toFixed(1);
                    } else if (subType === 2) { // 분수 덧셈뺄셈
                        let d = rand(2, 9), n1 = rand(-9, 9), n2 = rand(-9, 9), op = Math.random() > 0.5 ? '+' : '-';
                        q = `${fmtFrac(n1, d)} ${op} ${fmtFrac(n2, d)}`;
                        currentAns = (op === '+' ? n1 + n2 : n1 - n2) + "/" + d;
                    } else { // 분수 곱셈나눗셈
                        let n1 = rand(-9, 9), d1 = rand(-9, 9); if (d1 === 0) d1 = 7;
                        let n2 = rand(-9, 9), d2 = rand(-9, 9); if (d2 === 0) d2 = 3;
                        let op = Math.random() > 0.5 ? '\\times' : '\\div';
                        if (op === '\\times') {
                            q = `${fmtFrac(n1, d1)} \\times ${fmtFrac(n2, d2)}`;
                            currentAns = (n1 * n2) + "/" + (d1 * d2);
                        } else {
                            if (n2 === 0) n2 = 5; 
                            q = `${fmtFrac(n1, d1)} \\div ${fmtFrac(n2, d2)}`;
                            currentAns = (n1 * d2) + "/" + (d1 * n2);
                        }
                    }
                }
            } 
            else { // 허들 모드
                if (lv === 1) {
                    let n1 = rand(-10, 10), n2 = rand(-10, 10), op = Math.random() > 0.5 ? '+' : '-';
                    q = `${fmt(n1)} ${op} ${fmt(n2)}`;
                    currentAns = (op === '+' ? n1 + n2 : n1 - n2).toString();
                } 
                else if (lv === 2) {
                    if (Math.random() > 0.5) {
                        let d = rand(2, 9), n1 = rand(-9, 9), n2 = rand(-9, 9), op = Math.random() > 0.5 ? '+' : '-';
                        q = `${fmtFrac(n1, d)} ${op} ${fmtFrac(n2, d)}`;
                        currentAns = (op === '+' ? n1 + n2 : n1 - n2) + "/" + d;
                    } else {
                        let makeDec = () => {
                            let sign = Math.random() > 0.5 ? 1 : -1;
                            let integral = rand(0, 9); let fractional = rand(1, 9); 
                            return (sign * (integral + fractional / 10)).toFixed(1);
                        };
                        let d1 = makeDec(), d2 = makeDec(), op = Math.random() > 0.5 ? '+' : '-';
                        q = `${fmt(d1)} ${op} ${fmt(d2)}`;
                        let res = op === '+' ? parseFloat(d1) + parseFloat(d2) : parseFloat(d1) - parseFloat(d2);
                        currentAns = res.toFixed(1);
                    }
                }
                else if (lv === 3) {
                    let n1 = rand(-9, 9), n2 = rand(-9, 9); if (n2 === 0) n2 = 2;
                    let op = Math.random() > 0.5 ? '\\times' : '\\div';
                    if (op === '\\times') { q = `${fmt(n1)} \\times ${fmt(n2)}`; currentAns = (n1 * n2).toString(); }
                    else { q = `${fmt(n1)} \\div ${fmt(n2)}`; currentAns = n1 + "/" + n2; }
                } 
                else if (lv === 4) {
                    let n1 = rand(-9, 9), d1 = rand(-9, 9); if (d1 === 0) d1 = 7;
                    let n2 = rand(-9, 9), d2 = rand(-9, 9); if (d2 === 0) d2 = 3;
                    q = `${fmtFrac(n1, d1)} \\times ${fmtFrac(n2, d2)}`;
                    currentAns = (n1 * n2) + "/" + (d1 * d2);
                } 
                else if (lv === 5) {
                    let n1 = rand(-9, 9), d1 = rand(-9, 9); if (d1 === 0) d1 = 7;
                    let n2 = rand(-9, 9), d2 = rand(-9, 9); if (d2 === 0) d2 = 3;
                    if (n2 === 0) n2 = 5; 
                    q = `${fmtFrac(n1, d1)} \\div ${fmtFrac(n2, d2)}`;
                    currentAns = (n1 * d2) + "/" + (d1 * n2);
                }
                else if (lv === 6) {
                    let n1 = rand(-9, 9), d1 = rand(2, 9), n2 = rand(-2, 2), n3 = rand(-2, 2);
                    if (Math.random() > 0.5) q = `${fmtFrac(n1, d1)} + ${fmt(n2)} \\times ${fmt(n3)}`;
                    else q = `${fmt(n2)} \\times ${fmt(n3)} + ${fmtFrac(n1, d1)}`;
                    currentAns = (n1 + n2 * n3 * d1) + "/" + d1;
                } 
                else {
                    let type = rand(1, 3);
                    if (type === 1) {
                        let a = rand(2, 9), b = rand(1, 9), c = rand(1, 9), n = rand(2, 9), den = rand(2, 9), num = rand(-15, 15);
                        q = `${fmt(a)}^{${n}} - \\left[ ${fmt(b)} - \\left\\{ ${fmt(c)} - ${fmtFrac(num, den)} \\right\\} \\right]`;
                        currentAns = (den * (Math.pow(a, n) - b + c) - num) + "/" + den;
                    }
                    else if (type === 2) {
                        let den = rand(2, 9), num_a = rand(-15, 15), num_d = rand(-15, 15), b = rand(-9, 9), c = rand(-2, -1), n = rand(2, 3);
                        q = `\\left[ ${fmtFrac(num_a, den)} - \\left\\{ ${fmt(b)} - ${fmt(c)}^{${n}} \\right\\} \\right] + ${fmtFrac(num_d, den)}`;
                        currentAns = (num_a + num_d - den * (b - Math.pow(c, n))) + "/" + den;
                    }
                    else {
                        let den = rand(2, 9), num_a = rand(-15, 15), b = rand(-3, 4), c = rand(-3, -1), n = rand(2, 3);
                        q = `${fmtFrac(num_a, den)} - \\left\\{ ${fmt(b)} + ${fmt(c)}^{${n}} \\right\\}`;
                        currentAns = (num_a - den * (b + Math.pow(c, n))) + "/" + den;
                    }
                }
            }
            
            currentProblemTex = q;
            document.getElementById('math-problem').innerHTML = `\\[ ${q} \\]`;
            MathJax.typesetPromise([document.getElementById('math-problem')]);
        }

        function checkAnswer() {
            if(currentInput==="") return; 
            let uVal=parseFraction(currentInput), aVal=parseFraction(currentAns);
            let isCorrect = (!isNaN(uVal) && Math.abs(uVal-aVal)<0.00001);

            if (gameMode === 'timeattack') {
                if(isCorrect) {
                    taCorrectCount++;
                    score += 10 + (combo*5);
                    combo++;
                    document.getElementById('hurdle-container').classList.add('hurdle-pass');
                    if(combo>1){let cb=document.getElementById('combo-pop'); cb.innerText=combo+" COMBO!"; cb.style.opacity="1"; cb.style.transform="scale(1.2)"; setTimeout(()=>{cb.style.opacity="0";},800);}
                    setTimeout(()=>{ updateUI(); nextQuestion(); }, 400);
                } else {
                    taWrongCount++;
                    combo = 0;
                    wrongLog.push({problem:currentProblemTex, user:currentInput, correct:currentAns});
                    let b = document.getElementById('hurdle-bar');
                    b.classList.remove('shake'); void b.offsetWidth; b.classList.add('shake');
                    b.style.backgroundColor = '#EF9A9A';
                    setTimeout(()=>{ updateUI(); nextQuestion(); }, 500); // 틀려도 바로 다음 문제로
                }
            } else {
                // 허들 모드
                if(!isCorrect){triggerFail();return;}
                score+=(lv===7?100:lv*10)+(combo*5); combo++; streak++; 
                if(combo>1){let cb=document.getElementById('combo-pop'); cb.innerText=combo+" COMBO!"; cb.style.opacity="1"; cb.style.transform="scale(1.2)"; setTimeout(()=>{cb.style.opacity="0";},800);}
                document.getElementById('hurdle-container').classList.add('hurdle-pass');
                setTimeout(()=>{ 
                    if(streak>=5){ 
                        if(lv<7){ 
                            lv++; streak=0;
                            document.body.style.backgroundColor=bgColors[lv-1];
                            updateRunnerPosition(lv); 
                        } else{
                            endTime=Date.now();gameOver(true);return;
                        } 
                    } 
                    updateUI(); nextQuestion(); 
                }, 400);
            }
        }

        function triggerFail() { 
            wrongLog.push({problem:currentProblemTex, user:currentInput, correct:currentAns}); 
            combo=0; streak=0; strikes++; 
            let b=document.getElementById('hurdle-bar'); 
            b.classList.remove('shake'); void b.offsetWidth; b.classList.add('shake'); 
            b.style.backgroundColor=strikes===1?'#FFF59D':'#EF9A9A'; 
            if(strikes>=3){endTime=Date.now();gameOver(false);} 
            currentInput=""; renderInput(); updateUI(); 
        }

        function updateUI() { 
            document.getElementById('score-text').innerText=score; 
            if (gameMode === 'hurdle') {
                document.getElementById('lv-text').innerText=lv; 
                document.getElementById('streak-text').innerText=streak; 
            } else {
                document.getElementById('ta-correct-text').innerText=taCorrectCount;
                document.getElementById('ta-wrong-text').innerText=taWrongCount;
            }
        }

        function gameOver(isWin) {
            if(taTimer) clearInterval(taTimer);
            document.getElementById('result-screen').style.display='flex';
            
            let best = parseInt(localStorage.getItem('h_best') || "0");
            if(score > best) best = score; 

            document.getElementById('display-id').innerHTML = `학번: ${studentId}`;
            document.getElementById('res-score').innerText=score+"점";
            
            let sec=((endTime-startTime)/1000).toFixed(1);
            
            if (gameMode === 'hurdle') {
                document.getElementById('res-title').innerText = "허들 레이스 결과";
                document.getElementById('display-id').innerHTML += ` <span style="margin-left:15px; color:#ef5350;">(최고 기록: ${best}점)</span>`;
                document.getElementById('res-ta-stats').style.display = 'none';
                document.getElementById('history-area').style.display = 'block';
                document.getElementById('time-text').innerText=isWin?"🚀 모든 허들 정복! 소요시간: "+sec+"초":"⏱ 소요시간: "+sec+"초";
                
                let history = JSON.parse(localStorage.getItem('h_history') || "[]");
                history.push({ score: score, time: sec });
                if(history.length > 5) history = history.slice(-5);
                localStorage.setItem('h_history', JSON.stringify(history));
                
                let historyHtml = "";
                for(let i = history.length - 1; i >= 0; i--) {
                    historyHtml += `<li>${i + 1}회차: <span style="color:#1976d2; font-weight:bold;">${history[i].score}점</span> (${history[i].time}초)</li>`;
                }
                document.getElementById('history-list').innerHTML = historyHtml;
                
                if(score > parseInt(localStorage.getItem('h_best') || "0")) { 
                    localStorage.setItem('h_best', score); 
                    localStorage.setItem('h_best_time', sec); 
                }
            } else {
                // 타임어택 결과
                document.getElementById('res-title').innerText = "타임어택 결과";
                document.getElementById('res-ta-stats').style.display = 'block';
                document.getElementById('history-area').style.display = 'none';
                document.getElementById('res-ta-o').innerText = taCorrectCount + "개";
                document.getElementById('res-ta-x').innerText = taWrongCount + "개";
                document.getElementById('time-text').innerText="훈련 종료! (3분 소요)";
            }

            let attempts = parseInt(localStorage.getItem('h_attempts') || "0") + 1;
            localStorage.setItem('h_attempts', attempts);

            let w=document.getElementById('wrong-list');
            if(wrongLog.length===0) {
                w.innerHTML="<li style='text-align:center;'>오답이 없습니다! 🎉 PERFECT!</li>";
            } else { 
                let logHtml = "";
                // 모든 오답을 역순(최신순)으로 보여주기
                for(let i=wrongLog.length-1; i>=0; i--){
                    let l = wrongLog[i];
                    logHtml += `<li>문제: \\( ${l.problem} \\)<br><span class="ans-user">나의 답: \\( ${toLatex(l.user)} \\)</span><span class="ans-correct">정답: \\( ${toLatex(l.correct)} \\)</span></li>`;
                }
                w.innerHTML = logHtml;
            }
            MathJax.typesetPromise([w]);
            
            let weakTypeDisplay = "분석 불가";
            if (gameMode === 'timeattack') {
                if(taCategory === 1) weakTypeDisplay = "정수 덧셈/뺄셈 반복 훈련";
                else if(taCategory === 2) weakTypeDisplay = "정수 곱셈/나눗셈 반복 훈련";
                else weakTypeDisplay = "유리수 사칙계산 반복 훈련";
            } else {
                if (wrongLog.length > 0) {
                    let lastProb = wrongLog[wrongLog.length - 1].problem;
                    if (lastProb.includes('^')) weakTypeDisplay = "거듭제곱 혼합계산";
                    else if (lastProb.includes('\\{') || lastProb.includes('\\[')) weakTypeDisplay = "복잡한 괄호 계산";
                    else if (lastProb.includes('\\frac') && (lastProb.includes('\\times') || lastProb.includes('\\div'))) weakTypeDisplay = "유리수 곱셈/나눗셈";
                    else if (lastProb.includes('\\frac') || lastProb.includes('.')) weakTypeDisplay = "유리수 덧셈/뺄셈";
                    else if (lastProb.includes('\\times') || lastProb.includes('\\div')) weakTypeDisplay = "정수 곱셈/나눗셈";
                    else weakTypeDisplay = "정수 덧셈/뺄셈";
                } else { weakTypeDisplay = "약점 없음! 완벽합니다."; }
            }
            document.getElementById('weak-type-display').innerText = "💡 " + weakTypeDisplay;
        }

        function submitToGoogle() {
            if(!webAppUrl || webAppUrl.includes("여기에")) { alert("선생님! 코드에 웹 앱 URL을 먼저 설정해 주세요."); return; }
            let btn = document.getElementById('submit-btn');
            btn.innerText = "제출 중..."; btn.disabled = true;
            
            let finalTime = gameMode === 'timeattack' ? "180.0" : ((endTime - startTime) / 1000).toFixed(1);
            let bestScore = localStorage.getItem('h_best') || score;
            let bestTime = localStorage.getItem('h_best_time') || finalTime;
            let attempts = localStorage.getItem('h_attempts') || 1;
            
            let lastProblem = "없음";
            let lastAnswer = "없음";
            if (wrongLog.length > 0) {
                lastProblem = wrongLog[wrongLog.length - 1].problem;
                lastAnswer = wrongLog[wrongLog.length - 1].user;
            }
            
            let weakType = document.getElementById('weak-type-display').innerText.replace("💡 ", "");
            if(gameMode === 'timeattack') weakType = "[TA] " + weakType; // 구글 시트에서 타임어택인지 구분하기 위해
            
            let url = `${webAppUrl}?studentId=${encodeURIComponent(studentId)}&score=${score}&bestScore=${bestScore}&attempts=${attempts}&time=${finalTime}&bestTime=${bestTime}&lastProblem=${encodeURIComponent(lastProblem)}&lastAnswer=${encodeURIComponent(lastAnswer)}&weakType=${encodeURIComponent(weakType)}`;
            
            fetch(url, { mode: 'no-cors' }).then(() => {
                btn.innerText = "제출 완료!";
                alert("결과가 선생님께 안전하게 전송되었습니다.");
            }).catch(() => {
                alert("제출에 실패했습니다. 인터넷 연결을 확인해 주세요.");
                btn.disabled = false; btn.innerText = "결과 제출하기";
            });
        }

        function adjustScreenSize() {
            let scale = Math.min(window.innerWidth / 500, window.innerHeight / 850);
            if (scale > 1.2) scale = 1.2; 
            document.querySelectorAll('.screen').forEach(screen => {
                screen.style.transform = `translate(-50%, -50%) scale(${scale})`;
            });
        }

        window.addEventListener('resize', adjustScreenSize);
        window.addEventListener('DOMContentLoaded', adjustScreenSize);
        adjustScreenSize();

        window.addEventListener('DOMContentLoaded', () => {
            let savedId = localStorage.getItem('h_last_id');
            if (savedId) document.getElementById('student-id').value = savedId;
        });
     
        function resetGame() {
            if(taTimer) { clearInterval(taTimer); taTimer = null; }
            lv = 1; score = 0; combo = 0; streak = 0; strikes = 0;
            wrongLog = [];
            
            let btn = document.getElementById('submit-btn');
            btn.innerText = "결과 제출하기";
            btn.disabled = false;
            
            document.getElementById('result-screen').style.display = 'none';
            document.getElementById('game-screen').style.display = 'none';
            document.getElementById('start-screen').style.display = 'flex';
        }
    </script>
</body>
</html>
